# OpenClaw 桥接器环境变量配置示例
# 复制此文件为 .env 并填入实际值，或设置系统环境变量

# ===== SillyMD API 配置（必填）=====
# API Key - 从 SillyMD 控制台获取
SILLYMD_API_KEY=your_api_key_here

# ===== 企业微信配置（必填）=====
# 企业微信 CorpID
WECOM_CORP_ID=wwxxxxxxxxxxxxxxxx

# 企业微信应用凭证
WECOM_CORP_SECRET=your_corp_secret_here

# 企业微信 Token（消息加解密）
WECOM_TOKEN=your_token_here

# 企业微信 EncodingAESKey（消息加解密）
WECOM_ENCODING_AES_KEY=your_aes_key_here

# 企业微信应用 ID
WECOM_AGENT_ID=1000001

# ===== 用户配置 =====
# 企业微信消息接收者（owner_id）
WECOM_OWNER_ID=YourName

# ===== OpenClaw 配置（可选）=====
# OpenClaw 命令路径（可选，如果不设置会自动检测）
# OPENCLAW_CMD=C:\Users\YourName\AppData\Roaming\npm\openclaw.cmd

# Agent 名称（默认: main）
# OPENCLAW_AGENT=main

# ===== 配置说明 =====
# 优先级（从高到低）：
# 1. 系统环境变量
# 2. .env 文件中的变量
# 3. 硬编码默认值（向后兼容）

# ===== Windows PowerShell 设置示例 =====
# $env:SILLYMD_API_KEY="your_api_key"
# $env:WECOM_CORP_ID="wwxxxxxxxxxxxxxxxx"
# $env:WECOM_CORP_SECRET="your_corp_secret"
# $env:WECOM_TOKEN="your_token"
# $env:WECOM_ENCODING_AES_KEY="your_aes_key"
# $env:WECOM_OWNER_ID="YourName"

# ===== Linux/Mac Bash 设置示例 =====
# export SILLYMD_API_KEY=your_api_key
# export WECOM_CORP_ID=wwxxxxxxxxxxxxxxxx
# export WECOM_CORP_SECRET=your_corp_secret
# export WECOM_TOKEN=your_token
# export WECOM_ENCODING_AES_KEY=your_aes_key
# export WECOM_OWNER_ID=YourName
